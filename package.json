{
  "name": "tzero-blog",
  "version": "1.0.0",
  "description": "Tzero - An engineering and operations blog focused on reducing toil, cognitive load, and the inclusion of AIOps in every day life.",
  "main": "index.js",
  "scripts": {
    "dev:generate": "npx tailwindcss -i ./input.css -o ./themes/pehtheme-hugo/assets/css/main.css -w",
    "dev:hugo": "hugo server -D",
    "dev": "run-p dev:*",
    "build:generate": "npx tailwindcss -i ./input.css -o ./themes/pehtheme-hugo/assets/css/main.css --minify",
    "build:hugo": "hugo --minify",
    "build": "run-s build:*"
  },
  "keywords": [
    "hugo",
    "tailwindcss",
    "blog",
    "tzero",
    "devops",
    "mlops",
    "aiops"
  ],
  "author": "Tzero Editorial Team",
  "license": "MIT",
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "autoprefixer": "^10.4.27",
    "npm-run-all2": "^8.0.4",
    "postcss": "^8.5.8",
    "postcss-cli": "^11.0.1",
    "tailwindcss": "^3.4.0"
  }
}
